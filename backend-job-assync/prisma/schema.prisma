generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// MULTI-TENANT: Usuarios e Organizacoes
// ===========================================

// Usuario sincronizado do Auth Service
model User {
  id            String     @id // ID vem do Auth Service
  email         String     @unique
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  displayName   String?    @map("display_name")
  avatarUrl     String?    @map("avatar_url")
  status        UserStatus @default(ACTIVE)

  // Relacionamentos
  memberships OrganizationMember[]
  jobs        Job[]
  recurringJobs RecurringJob[]
  auditLogs   AuditLog[]

  // Sincronizacao
  lastSyncAt DateTime @default(now()) @map("last_sync_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Organizacao (tenant) sincronizada do Auth Service
model Organization {
  id       String  @id // ID vem do Auth Service
  slug     String  @unique
  name     String
  logoUrl  String? @map("logo_url")
  settings Json? // Configuracoes especificas do JobSync

  // Relacionamentos
  members   OrganizationMember[]
  apiKeys   ApiKey[]
  queues    Queue[]
  jobs      Job[]
  recurringJobs RecurringJob[]
  auditLogs AuditLog[]

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Sincronizacao
  lastSyncAt DateTime @default(now()) @map("last_sync_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("organizations")
}

// Membro da organizacao (vinculo usuario-org com role)
model OrganizationMember {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  organizationId String     @map("organization_id")
  role           MemberRole @default(MEMBER)
  permissions    String[] // Permissoes especificas do JobSync

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  joinedAt   DateTime @default(now()) @map("joined_at")
  lastSyncAt DateTime @default(now()) @map("last_sync_at")

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ===========================================
// API KEYS para autenticacao machine-to-machine
// ===========================================

model ApiKey {
  id   String  @id @default(cuid())
  key  String  @unique
  name String

  description String?

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String? @map("created_by_id") // Usuario que criou

  // Permissoes da API Key
  permissions    String[] // Ex: ["jobs:create", "jobs:read", "queues:read"]
  allowedDomains String[] @map("allowed_domains") // Dominios permitidos para callbacks
  allowedIps     String[] @map("allowed_ips") // IPs permitidos (vazio = todos)

  // Rate limiting
  rateLimit Int? @map("rate_limit") // Requests por minuto (null = sem limite)

  // Status
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at")

  // Auditoria
  lastUsedAt DateTime? @map("last_used_at")
  usageCount Int       @default(0) @map("usage_count")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([key])
  @@index([organizationId])
  @@map("api_keys")
}

// ===========================================
// FILAS E JOBS
// ===========================================

model Queue {
  id          String  @id @default(cuid())
  name        String
  description String?

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jobs Job[]
  recurringJobs RecurringJob[]

  // Configuracoes
  concurrency Int  @default(5)
  maxRetries  Int  @default(3) @map("max_retries")
  retryDelay  Int  @default(5000) @map("retry_delay") // ms
  timeout     Int  @default(300000) // 5 min
  rateLimit   Int? @map("rate_limit") // jobs por minuto

  // Status
  isActive Boolean @default(true) @map("is_active")
  isPaused Boolean @default(false) @map("is_paused")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("queues")
}

model Job {
  id         String  @id @default(cuid())
  externalId String? @map("external_id") // ID do app cliente

  // Multi-tenant
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  queueId String @map("queue_id")
  queue   Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)

  // Usuario que criou (opcional, pode ser API Key)
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // URLs
  webhookUrl    String  @map("webhook_url") // URL para processar
  webhookMethod String  @default("POST") @map("webhook_method") // HTTP method (GET, POST, PUT, DELETE)
  callbackUrl   String? @map("callback_url") // URL para entregar resultado

  // Dados
  payload Json
  result  Json?
  error   String?

  // Status
  status   JobStatus @default(PENDING)
  priority Int       @default(0)

  // Execucao
  attempts    Int @default(0)
  maxAttempts Int @default(3) @map("max_attempts")

  // Agendamento
  scheduledAt DateTime? @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Recorrencia
  recurrenceId  String?       @map("recurrence_id")
  recurrenceJob RecurringJob? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)

  // Metadata
  metadata Json?
  tags     String[] // Tags para filtragem

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs JobLog[]

  @@index([organizationId])
  @@index([queueId])
  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([externalId])
  @@index([recurrenceId])
  @@map("jobs")
}

enum JobStatus {
  PENDING
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  DEAD // falhou todas tentativas
}

model JobLog {
  id    String @id @default(cuid())
  jobId String @map("job_id")
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  attempt  Int
  status   String
  message  String?
  duration Int? // ms
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@index([createdAt])
  @@map("job_logs")
}

// ===========================================
// RECURRING JOBS
// ===========================================

model RecurringJob {
  id              String   @id @default(cuid())
  name            String
  description     String?

  organizationId  String   @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  queueId         String   @map("queue_id")
  queue           Queue    @relation(fields: [queueId], references: [id])

  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Configuração da recorrência
  recurrenceType  RecurrenceType
  interval        Int?
  cronExpression  String?         @map("cron_expression")

  // Configuração do webhook
  webhookUrl      String   @map("webhook_url")
  webhookMethod   String   @default("POST") @map("webhook_method")
  callbackUrl     String?  @map("callback_url")
  payloadTemplate Json     @map("payload_template")

  // Limites e comportamento
  maxRuns         Int?     @map("max_runs")
  recurrenceEndDate DateTime?  @map("recurrence_end_date")
  continueOnFailure Boolean @default(false) @map("continue_on_failure")

  // Status
  isActive        Boolean  @default(true) @map("is_active")
  nextRunAt       DateTime @map("next_run_at")

  // Execuções
  jobs            Job[]

  metadata        Json?
  tags            String[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([queueId])
  @@index([nextRunAt])
  @@index([isActive])
  @@map("recurring_jobs")
}

enum RecurrenceType {
  INTERVAL
  CRON
}

// ===========================================
// AUDIT LOG
// ===========================================

model AuditLog {
  id String @id @default(cuid())

  // Quem fez
  userId         String?       @map("user_id")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // O que fez
  action     String // Ex: "job.created", "queue.updated", "apikey.revoked"
  entityType String? @map("entity_type") // Ex: "Job", "Queue", "ApiKey"
  entityId   String? @map("entity_id")

  // Detalhes
  metadata  Json?
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Resultado
  status AuditStatus @default(SUCCESS)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditStatus {
  SUCCESS
  FAILURE
  DENIED
}
