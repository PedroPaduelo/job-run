    "@prisma/client": "^5.8.0",
    "@sentry/node": "^7.100.0",
    "bullmq": "^5.1.0",
    "cron": "^3.1.0",
    "cron-parser": "^5.5.0",
    "cuid": "^3.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
